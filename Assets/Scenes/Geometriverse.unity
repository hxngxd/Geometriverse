  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u2022 Gi\u1EDBi thi\u1EC7u\n\t- Geometriverse l\xE0 m\u1ED9t c\xF4ng
    c\u1EE5 v\u1EBD h\xECnh kh\xF4ng gian ph\u1EE5c v\u1EE5 cho l\u0129nh v\u1EF1c
    gi\u1EA3ng d\u1EADy m\xF4n h\xECnh h\u1ECDc \u1EDF tr\xECnh \u0111\u1ED9 ph\u1ED5
    th\xF4ng. Geometriverse d\u1EC5 s\u1EED d\u1EE5ng v\xE0 b\u1EAFt m\u1EAFt h\u01A1n
    so v\u1EDBi nh\u1EEFng c\xF4ng c\u1EE5 kh\xE1c, c\xF9ng v\u1EDBi \u0111\xF3 l\xE0
    nh\u1EEFng ch\u1EE9c n\u0103ng th\xFA v\u1ECB v\xE0 \u0111\u1EB7c bi\u1EC7t l\xE0
    ch\u1EBF \u0111\u1ED9 t\u01B0\u01A1ng t\xE1c tr\u1EF1c tuy\u1EBFn qua m\u1EA1ng
    Internet.\n\u2022 Phi\xEAn b\u1EA3n\n\t- Geometriverse \u0111ang trong qu\xE1
    tr\xECnh nghi\xEAn c\u1EE9u v\xE0 ph\xE1t tri\u1EC3n, ch\u01B0a ch\xEDnh th\u1EE9c
    ph\xE1t h\xE0nh.\n\u2022 Li\xEAn h\u1EC7\n\t- Gmail: hungtuong05@gmail.com\n\t-
    Github: https://github.com/hxngxd"
